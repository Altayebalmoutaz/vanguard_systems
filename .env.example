# Copy to .env and fill in (Supabase: Project Settings → API)
SUPABASE_URL=
# Server: prefer SUPABASE_SERVICE_ROLE_KEY (bypasses RLS). Otherwise use anon + policies (see supabase/migrations/003).
SUPABASE_SERVICE_ROLE_KEY=
# Eligibility agent also accepts SUPABASE_KEY (same value as service role if you prefer that name).
# SUPABASE_KEY=

# Eligibility POST /eligibility/check optional fields — with migration 040 mock seeds:
# practice_id=vgd_mock_brooklyn, rendering_provider_npi=1104023674, optional provider_service_location_key=site_main
# Layer 5 uses provider_payer_network.in_network_for_fees (fee path) vs Stedi 271 in_network (audit).

# Layer 5: when payer_fee_schedules has no row for a CDT, fill illustrative UCR (off by default).
# ELIGIBILITY_UCR_FALLBACK_ENABLED=true
# Optional JSON overrides: {"D1110": 200, "D2740": 1200}
# ELIGIBILITY_UCR_FALLBACK_JSON=

# Optional: provider_organization_name (Stedi provider.organizationName), provider_first_name / provider_last_name.

# Stedi eligibility — https://www.stedi.com/docs (healthcare API key)
STEDI_API_KEY=
# Set true when using Stedi test key + official dental mock scenarios (sends stedi-test: true).
# STEDI_TEST_HEADER=true
# Optional overrides; defaults are mock-safe for sandbox (see eligibility_agent/config.py).
# PROVIDER_NPI=
# PROVIDER_NAME=
# PROVIDER_TAX_ID=

# Stedi 837 (claim submission) — separate Healthcare Claims API key, may be the
# same project as eligibility but is checked independently so claims can stay in
# mock mode while eligibility runs live, or vice versa.
# When unset, app/tools/claim_tools.py falls back to the deterministic mock
# (`submission_channel = stedi_mock`). When set, claims POST to
# `${STEDI_CLAIMS_BASE_URL}${STEDI_CLAIMS_DENTAL_PATH}` with `Authorization: Key ...`.
# STEDI_CLAIMS_API_KEY=
# STEDI_CLAIMS_BASE_URL=https://healthcare.us.stedi.com
# STEDI_CLAIMS_DENTAL_PATH=/2024-04-01/change/medical/claims
# STEDI_CLAIMS_TEST_HEADER=true
# STEDI_CLAIMS_TIMEOUT_SECONDS=30
# scripts/backfill_cdt_embeddings.py also accepts:
# SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
# Optional: database password (Settings → Database) for scripts/apply_rcm_schema.py — or set DATABASE_URL instead.
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://your-site.example

# Jina embeddings — https://jina.ai/
# JINA_API_KEY=
# JINA_EMBEDDING_MODEL=jina-embeddings-v5-text-small
# JINA_EMBEDDING_DIMENSIONS=1024
# JINA_BATCH_SIZE=10
# Coding agent: with JINA_API_KEY + Supabase, injects pgvector `match_cdt_codes` hints into the coding LLM prompt.
# CDT_VECTOR_MATCH_COUNT=8
# CDT_VECTOR_MATCH_THRESHOLD=0.3
# Optional: only rows with this status (otherwise all rows with null embedding)
# CDT_EMBED_STATUS=active
# scripts/backfill_cdt_embeddings.py (Vanguard CDT backfill) also reads SUPABASE_SERVICE_KEY (or SUPABASE_SERVICE_ROLE_KEY).

# --- Authentication (production) ---
# Flip to 1 in any non-local deployment. When on, every non-/health route requires
# Authorization: Bearer <Supabase JWT> OR X-API-Key: <one of INTERNAL_API_KEYS>.
# REQUIRE_AUTH=0
# HS256 secret for verifying Supabase user JWTs (Project Settings → API → JWT Settings).
# SUPABASE_JWT_SECRET=
# Comma-separated allow-list of static API keys for trusted server-to-server callers
# (Supabase edge functions, batch jobs, ops scripts). Keep entries 32+ random chars.
# INTERNAL_API_KEYS=svc-key-1,svc-key-2

# --- Eligibility webhook (Supabase Edge → local FastAPI via ngrok) ---
# Vault secret `eligibility_agent_check_url` (or Edge ELIGIBILITY_AGENT_CHECK_URL) must match HOW you run uvicorn:
#
#   • Full app (recommended if you already use port 8000):
#       uvicorn app.main:app --host 0.0.0.0 --port 8000
#       ngrok http 8000
#       URL: https://<subdomain>.ngrok-free.app/eligibility-agent/eligibility/check
#
#   • Eligibility-only app on 8010:
#       uvicorn app.eligibility.main:app --host 0.0.0.0 --port 8010
#       ngrok http 8010
#       URL: https://<subdomain>.ngrok-free.app/eligibility/check
#
# Wrong path for the mode you use → HTTP 404 → dashboard shows AGENT_ERROR / "Not Found".
# Same random value on FastAPI and Supabase Edge for `ELIGIBILITY_AGENT_API_KEY`:
# ELIGIBILITY_AGENT_API_KEY=

# --- OpenDental ---
# Default for demo mode: Open Dental Local API running on the same Windows machine.
# Local API endpoint (inside opendental.exe): http://localhost:30222/api/v1
OPENDENTAL_BASE_URL=http://localhost:30222/api/v1
# Required auth for all API modes: Authorization: ODFHIR {DeveloperKey}/{CustomerKey}
OPENDENTAL_DEVELOPER_KEY=
OPENDENTAL_CUSTOMER_KEY=
OPENDENTAL_TIMEOUT_SECONDS=15
# Safety gate: only when true can /eligibility/from-opendental write back via PUT /insverifies.
OPENDENTAL_WRITEBACK_ENABLED=false
# Optional replay mode (tests/demo fallback): read fixtures instead of HTTP calls.
# OPENDENTAL_REPLAY_DIR=tests/fixtures/opendental
